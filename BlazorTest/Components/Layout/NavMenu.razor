@using Domain.Models
@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row pe-3 navbar navbar-dark justify-content-end">
    <div class="container-fluid justify-content-end">
        <AuthorizeView>
            <Authorized>
                <span class="navbar-text me-3 text-white">
                    Hello, @context.User.Identity?.Name!
                </span>
            </Authorized>
            <NotAuthorized>
                <a class="navbar-brand" href="">Account</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

<input type="checkbox" title="Account menu" class="navbar-toggler" id="right-nav-toggler" />

<div class="nav-scrollable-right" onclick="document.getElementById('right-nav-toggler').click()">
    <nav class="nav flex-column">
        <AuthorizeView>
            <Authorized>
                <!-- Profile Link - Visible to all logged in users -->
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/profile-info">
                        <span class="bi bi-person-badge-fill" aria-hidden="true"></span> My Profile
                    </NavLink>
                </div>

                <!-- Admin specific shortcuts -->
                <AuthorizeView Roles="Admin" Context="innerContext">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/company-management">
                            <span class="bi bi-terminal-fill" aria-hidden="true"></span> Company Management
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/user-management">
                            <span class="bi bi-terminal-fill" aria-hidden="true"></span> Users Management
                        </NavLink>
                    </div>
                </AuthorizeView>

                <AuthorizeView Roles="Manager" Context="innerContext">
                    <div class="nav-item px-3">
                        @if (userCompanyId.HasValue)
                        {
                            <NavLink class="nav-link" href="@($"/my-employees/{userCompanyId}")">
                                <span class="bi bi-terminal-fill" aria-hidden="true"></span> My Employees
                            </NavLink>
                        }
                        else
                        {
                            <span class="nav-link text-muted">
                                <span class="bi bi-exclamation-circle" aria-hidden="true"></span> No Company Assigned
                            </span>
                        }
                    </div>
                </AuthorizeView>

                <AuthorizeView Roles="User" Context="innerContext">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="todo">
                            <span class="bi bi-list-check-nav-menu" aria-hidden="true"></span> My Tasks
                        </NavLink>
                    </div>
                </AuthorizeView>

                <div class="dropdown-divider"></div>

                <!-- Logout Action -->
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="" />
                        <button type="submit" class="nav-link btn btn-link text-start w-100 shadow-none">
                            <span class="bi bi-box-arrow-right" aria-hidden="true"></span> Logout
                        </button>
                    </form>
                </div>
            </Authorized>

            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/login">
                        <span class="bi bi-person-badge-fill" aria-hidden="true"></span> Log In
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/signup">
                        <span class="bi bi-person-plus-fill" aria-hidden="true"></span> Register
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private int? userCompanyId;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var authState = await AuthState;
            var user = authState.User;

            // Assuming you stored the CompanyId in a claim named "CompanyId"
            var companyClaim = user.FindFirst("CompanyId")?.Value;

            if (int.TryParse(companyClaim, out var id))
            {
                userCompanyId = id;
            }
        }
    }
}