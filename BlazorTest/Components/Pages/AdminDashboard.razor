@page "/admin/admin-dashboard"
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@using Application.Interfaces
@using Domain.Models
@inject IUserService UserService
@inject NavigationManager NavManager

<h3>Admin Panel: Manage Users</h3>

@if (CurrentUserRoles.Any(r => r.Equals("Admin", StringComparison.OrdinalIgnoreCase)))
{
    <button class="btn btn-success" @onclick="OpenRegistrationForm">Register New Staff</button>

    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in allUsers)
            {
                <tr>
                    <td>@user.Name @user.LastName</td>
                    <td>@user.Email</td>
                    <td>
                        <button class="btn btn-danger" @onclick="() => DeleteUser(user.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-danger">You do not have permission to view this page.</p>
}

@code {
    private List<User> allUsers = new();
    private List<string> CurrentUserRoles = new();

    protected override async Task OnInitializedAsync()
    {
        allUsers = await UserService.GetAllUsers();

        var testUser = allUsers.FirstOrDefault(u =>
            u.Email.Equals("admin1@example.com", StringComparison.OrdinalIgnoreCase));

        if (testUser?.UserRoles != null)
        {
            CurrentUserRoles = testUser.UserRoles
                .Where(ur => ur.Role != null)
                .Select(ur => ur.Role.Name)
                .ToList();

            foreach (var role in CurrentUserRoles)
            {
                Console.WriteLine($"Found Role: '{role}'");
            }
        }
    }

    private async Task DeleteUser(int id)
    {
        await UserService.DeleteById(id);
        allUsers = await UserService.GetAllUsers();
    }
    @code {
        private void OpenRegistrationForm()
        {
            NavManager.NavigateTo("/admin/register-user");
        }
    }
}

