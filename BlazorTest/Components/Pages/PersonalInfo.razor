@page "/personal-info"
@using Application.Interfaces
@using Domain.Models
@rendermode InteractiveServer
@inject IUserService UserService


<PageTitle>Personal Information</PageTitle>

<h1>Personal Information</h1>

<div style="margin-bottom: 20px;">
    <label>Name:</label>
    <br />
    <input type="text" @bind="firstName" style="width: 300px; padding: 8px; font-size: 16px;" />
</div>

<div style="margin-bottom: 20px;">
    <label>Surname:</label>
    <br />
    <input type="text" @bind="lastName" style="width: 300px; padding: 8px; font-size: 16px;" />
</div>

<div style="margin-bottom: 20px;">
    <label>Email:</label>
    <br />
    <input type="text" @bind="email" style="width: 300px; padding: 8px; font-size: 16px;" />
</div>

<div style="margin-bottom: 20px;">
    <label>AFM:</label>
    <br />
    <input type="text"
           value="@AFM"
           @oninput="OnAfmInput"
           style="width: 300px; padding: 8px; font-size: 16px;"
           maxlength="9" />

    @if (!string.IsNullOrEmpty(afmError))
    {
        <span style="color: red; font-weight: bold; font-size: 14px;">@afmError</span>
    }
</div>

<div style="margin-bottom: 20px;">
    <label>Phone Number:</label>
    <br />
    <input type="text" @bind="phoneNumber" style="width: 300px; padding: 8px; font-size: 16px;" />
</div>

<button class="btn btn-primary" @onclick="SubmitData">Save</button>

<div style="color: red; font-weight: bold; margin-top: 15px;">@errorMessage</div>
<div style="color: green; font-weight: bold; margin-top: 15px;">@successMessage</div>
<p>
 @fullstings
</p>

@code {
    private string firstName = "";
    private string lastName = "";
    private string email = "";
    private string AFM = "";
    private string phoneNumber = "";

    private string errorMessage = "";
    private string successMessage = "";
    private string fullstings = "";
    private string afmError = "";

    private void OnAfmInput(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";

        // Check for non-digits
        if (val.Any(c => !char.IsDigit(c)))
        {
            afmError = "Επιτρέπονται μόνο αριθμοί!";
        }
        else if (val.Length > 0 && val.Length < 9)
        {
            afmError = "Απαιτούνται 9 ψηφία.";
        }
        else
        {
            afmError = "";
        }

        AFM = new string(val.Where(char.IsDigit).ToArray());
    }

    private bool Validation()
    {
        errorMessage = "";

        if (firstName.Length < 3)
        {
            errorMessage = "Το όνομα πρέπει να έχει τουλάχιστον 3 γράμματα.";
            return false;
        }

        if (!Application.Utilities.VatValidator.ValidateVatNumber(AFM))
        {
            errorMessage = "Το ΑΦΜ δεν είναι έγκυρο. Πρέπει να έχει 9 ψηφία και σωστό αλγόριθμο.";
            return false;
        }

        successMessage = "Τα στοιχεία αποθηκεύτηκαν!";
        return true;
    }
    private async Task SubmitData()
    {
        if (!Validation())
            return;

        var user = new User
        {
            AFM = AFM,
            Name = firstName,
            LastName = lastName,
            Email = email,
            PhoneNumber = phoneNumber            
        };

        await UserService.Update(user);

        
    }
}